warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"30"},{"filePath":"31","messages":"32","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"33"},{"filePath":"34","messages":"35","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"36","messages":"37","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"38","messages":"39","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"40"},{"filePath":"41","messages":"42","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\Govindraj\\Desktop\\Sem2 Mini-Project\\OpenBook-main\\src\\index.js",[],"C:\\Users\\Govindraj\\Desktop\\Sem2 Mini-Project\\OpenBook-main\\src\\App.js",["43"],"import React from 'react';\r\nimport { BrowserRouter as Router, Route, Routes, Navigate } from 'react-router-dom';\r\nimport Main from './Components/Main';\r\nimport './Components/style.css';\r\nimport LoginPage from './Components/LoginPage';\r\nimport SignUpPage from './Components/SignUpPge';\r\n\r\n\r\n\r\n\r\nfunction App() {\r\n  return (\r\n    <>\r\n    {/* <SignUpPage/> */}\r\n    <Router>\r\n    <Routes> \r\n    <Route path=\"/Main\" element={<Main/>} />\r\n       <Route path=\"/\" element={<LoginPage/>} />\r\n       <Route path=\"/Signup\" element={<SignUpPage/>} />\r\n\r\n        \r\n      </Routes>\r\n    </Router>\r\n  \r\n    \r\n    </>\r\n  );\r\n}\r\n\r\nexport default App;\r\n","C:\\Users\\Govindraj\\Desktop\\Sem2 Mini-Project\\OpenBook-main\\src\\Components\\Main.js",["44","45","46"],"import react ,{useState}from \"react\";\r\nimport Card from \"./Card\";\r\nimport Footer from \"./Footer\";\r\nimport axios from \"axios\";\r\nconst Main=()=>{\r\n    const [search,setSearch]=useState(\"\");\r\n    const [bookData,setData]=useState([]);\r\n    const [error, setError] = useState(null);\r\n    const searchBook=(evt)=>{\r\n        if(evt.key===\"Enter\")\r\n        {\r\n            axios.get(\"https://www.googleapis.com/books/v1/volumes?q=\"+search+\"&key=AIzaSyCJtjb6uz2DfMgz8Ww9wWX5lzIr-N829j0\"+'&maxResults=40')\r\n            .then(res=>setData(res.data.items)(setError(null)))\r\n            .catch(err=>console.log(err)( setError(\"Error fetching data. Please try again.\")))\r\n        }\r\n    }\r\n    return(\r\n        <>\r\n        \r\n            <div className=\"header\">\r\n                <div className=\"row1\">\r\n                    <h1>A room without books is like<br/> a body without a soul.</h1>\r\n                </div>\r\n                <div className=\"row2\">\r\n                    <h2>Find Your Book</h2>\r\n                    <div className=\"search\">\r\n                        <input type=\"text\" placeholder=\"Enter Your Book Name\"\r\n                        value={search} onChange={e=>setSearch(e.target.value)}\r\n                        onKeyPress={searchBook}/>\r\n                        <button className=\"input-btn\"><i className=\"fas fa-search\"></i></button>\r\n                    </div>\r\n                    <img src=\"./images/bg9.png\" alt=\"A boy Reading Book\" />\r\n                </div>\r\n            </div>\r\n\r\n            <div className=\"container\">\r\n              {\r\n                    <Card book={bookData}/>\r\n              }  \r\n            </div>\r\n            <Footer/>\r\n        </>\r\n    )\r\n}\r\nexport default Main;","C:\\Users\\Govindraj\\Desktop\\Sem2 Mini-Project\\OpenBook-main\\src\\Components\\Card.js",["47","48","49"],"import { useState } from \"react\";\r\n// import  from \"react/cjs/react.development\";\r\nimport Modal from \"./Modal\";\r\nconst Card = ({ book }) => {\r\n\r\n    const [show,setShow]=useState(false);\r\n    const [bookItem,setItem]=useState();\r\n    console.log(book)\r\n    return (\r\n        <>\r\n            {\r\n                book.map((item) => {\r\n                    let thumbnail=item.volumeInfo.imageLinks && item.volumeInfo.imageLinks.smallThumbnail;\r\n                    let amount=item.saleInfo.listPrice && item.saleInfo.listPrice.amount;\r\n                    if(thumbnail!= undefined && amount !=undefined)\r\n                    {\r\n                        return (\r\n                            <>\r\n                            <div className=\"card\" onClick={()=>{setShow(true);setItem(item)}}>\r\n                                <img src={thumbnail} alt=\"\" />\r\n                                <div className=\"bottom\">\r\n                                    <h3 className=\"title\">{item.volumeInfo.title}</h3>\r\n                                    <p className=\"amount\">&#8377;{amount}</p>\r\n                                </div>\r\n                            </div>\r\n                              <Modal show={show} item={bookItem} onClose={()=>setShow(false)}/>\r\n                            </>\r\n                        )\r\n                    }\r\n                    \r\n                })\r\n            }\r\n        \r\n        </>\r\n    )\r\n}\r\nexport default Card;","C:\\Users\\Govindraj\\Desktop\\Sem2 Mini-Project\\OpenBook-main\\src\\Components\\Modal.js",["50"],"import react from 'react';\r\nconst Modal=({show,item,onClose})=>{\r\n    if(!show)\r\n    {\r\n        return null;\r\n    }\r\n    let thumbnail=item.volumeInfo.imageLinks && item.volumeInfo.imageLinks.smallThumbnail;\r\n    return(\r\n        <>\r\n            <div className=\"overlay\">\r\n                <div className=\"overlay-inner\">\r\n                    <button className=\"close\" onClick={onClose}><i class=\"fas fa-times\"></i></button>\r\n                    <div className=\"inner-box\">\r\n                        <img src={thumbnail} alt=\"\" />\r\n                        <div className=\"info\">\r\n                            <h1>{item.volumeInfo.title}</h1>\r\n                            <h3>{item.volumeInfo.authors}</h3>\r\n                            <h4>{item.volumeInfo.publisher}<span>{item.volumeInfo.publishedDate}</span></h4><br/>\r\n                            <a href={item.volumeInfo.previewLink}><button>More</button></a>\r\n                        </div>\r\n                    </div>\r\n                    <h4 className=\"description\"> <h3>Description :</h3>{item.volumeInfo.description}</h4>\r\n                </div>\r\n            </div>\r\n        </>\r\n    )\r\n}\r\nexport default Modal;","C:\\Users\\Govindraj\\Desktop\\Sem2 Mini-Project\\OpenBook-main\\src\\Components\\Footer.jsx",[],"C:\\Users\\Govindraj\\Desktop\\Sem2 Mini-Project\\OpenBook-main\\src\\Components\\LoginPage.jsx",["51"],"C:\\Users\\Govindraj\\Desktop\\Sem2 Mini-Project\\OpenBook-main\\src\\Components\\Navbar.jsx",["52"],"import React from 'react'\r\n\r\nfunction Navbar() {\r\n    return(\r\n        <>\r\n         <img className='nav-logo' src=\"./images/bg8.png\" alt=\"Image\" width=\"80px\" height=\"80px\"/>\r\n          <h1 className='nav-title'>BookBuddy</h1>\r\n        \r\n        </>\r\n    );\r\n}\r\n\r\nexport default Navbar;","C:\\Users\\Govindraj\\Desktop\\Sem2 Mini-Project\\OpenBook-main\\src\\Components\\SignUpPge.jsx",[],{"ruleId":"53","severity":1,"message":"54","line":2,"column":50,"nodeType":"55","messageId":"56","endLine":2,"endColumn":58},{"ruleId":"53","severity":1,"message":"57","line":1,"column":8,"nodeType":"55","messageId":"56","endLine":1,"endColumn":13},{"ruleId":"53","severity":1,"message":"58","line":8,"column":12,"nodeType":"55","messageId":"56","endLine":8,"endColumn":17},{"ruleId":"59","severity":1,"message":"60","line":12,"column":125,"nodeType":"61","messageId":"62","endLine":12,"endColumn":126},{"ruleId":"63","severity":1,"message":"64","line":12,"column":33,"nodeType":"65","messageId":"66","endLine":12,"endColumn":35},{"ruleId":"67","severity":1,"message":"68","line":15,"column":33,"nodeType":"61","messageId":"69","endLine":15,"endColumn":35},{"ruleId":"67","severity":1,"message":"68","line":15,"column":56,"nodeType":"61","messageId":"69","endLine":15,"endColumn":58},{"ruleId":"53","severity":1,"message":"57","line":1,"column":8,"nodeType":"55","messageId":"56","endLine":1,"endColumn":13},{"ruleId":"70","severity":1,"message":"71","line":80,"column":5,"nodeType":"72","endLine":80,"endColumn":32},{"ruleId":"73","severity":1,"message":"74","line":6,"column":10,"nodeType":"72","endLine":6,"endColumn":99},"no-unused-vars","'Navigate' is defined but never used.","Identifier","unusedVar","'react' is defined but never used.","'error' is assigned a value but never used.","no-useless-concat","Unexpected string concatenation of literals.","BinaryExpression","unexpectedConcat","array-callback-return","Array.prototype.map() expects a value to be returned at the end of arrow function.","ArrowFunctionExpression","expectedAtEnd","eqeqeq","Expected '!==' and instead saw '!='.","unexpected","jsx-a11y/anchor-is-valid","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","JSXOpeningElement","jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop."]